  "description": "GSD-PI extension that loads Squads ecosystem agents as native Pi SDK subagents, enabling squad workflows within autonomous GSD execution.",
  "author": "gutomec",
  "license": "MIT",
  "type": "module",
  "keywords": ["pi-package", "pi-extension", "squads", "multi-agent", "gsd-pi"],
  "repository": {
